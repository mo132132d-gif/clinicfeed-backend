# Runtime
NODE_ENV=development
PORT=4000
REQUEST_BODY_LIMIT=1mb

# Supabase PostgreSQL
# Get this from Supabase Dashboard > Project > Connect.
# Persistent backend with IPv6:
#   postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# Persistent backend without IPv6:
#   Use the Supavisor Session Pooler URI from the same Connect panel.
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_SSL=true
DB_POOL_MAX=10

# Security
# Use a long random value in production, for example 32+ bytes from a password manager.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12

# CORS
# Comma-separated origins are supported, for example:
# CORS_ORIGIN=https://suppliers.clinicfeed.com,http://localhost:3000
# Use * only for local/internal testing.
CORS_ORIGIN=http://localhost:3000

# Used by: npm run db:create-admin
ADMIN_NAME=ClinicFeed Admin
ADMIN_EMAIL=admin@clinicfeed.local
ADMIN_PASSWORD=change-this-password

# Used by: npm run db:seed
SEED_SAMPLE_PASSWORD=ClinicFeed123!
